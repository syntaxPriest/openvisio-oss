{
  "name": "@openvisio/core",
  "version": "0.1.0",
  "description": "Deterministic, local-first code-graph engine for OpenVisio: tree-sitter symbol/import extraction, PageRank ranking, token-budgeted skeletons and slices. No LLM, no network.",
  "type": "module",
  "license": "MIT",
  "author": "OpenVisio contributors",
  "homepage": "https://github.com/syntaxpriest/openvisio-oss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntaxpriest/openvisio-oss.git",
    "directory": "core"
  },
  "bugs": {
    "url": "https://github.com/syntaxpriest/openvisio-oss/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lmdb": "^3.2.6",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "~0.25.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
