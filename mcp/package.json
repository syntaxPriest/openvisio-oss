{
  "name": "openvisio",
  "version": "0.2.2",
  "description": "Cut your AI coding agent's token usage. MCP server + CLI that turns any codebase into a deterministic code graph and serves Claude Code, Cursor, Codex & Windsurf a ranked, token-budgeted query surface — agents query structure (symbols, imports, call edges, path:line anchors) instead of crawling files. ~30x fewer exploration tokens. Local-first, read-only, no network, no embeddings.",
  "type": "module",
  "license": "MIT",
  "author": "OpenVisio contributors",
  "homepage": "https://github.com/syntaxpriest/openvisio-oss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntaxpriest/openvisio-oss.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/syntaxpriest/openvisio-oss/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "token-savings",
    "reduce-tokens",
    "context-engineering",
    "code-graph",
    "code-knowledge-graph",
    "claude-code",
    "codex",
    "cursor",
    "windsurf",
    "cline",
    "ai-coding-agent",
    "ai-agents",
    "ai-pair-programmer",
    "tree-sitter",
    "static-analysis",
    "dependency-graph",
    "call-graph",
    "codebase-visualization",
    "code-map",
    "developer-tools",
    "local-first"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "openvisio": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "postinstall": "node dist/postinstall.js || exit 0",
    "prepublishOnly": "npm run typecheck && node build.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lmdb": "^3.2.6",
    "openvisio-viewer": "^0.2.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "~0.25.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@openvisio/core": "*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
