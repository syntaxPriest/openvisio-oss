# OpenVisio viewer environment. Everything is OPTIONAL — with none of these set,
# the viewer runs fully local-first. Copy to .env.local to override.

# Path to the built OpenVisio CLI used to index repos. Defaults to the sibling
# package in this monorepo (../mcp/dist/cli.js), so after `npm run build` at the
# repo root the viewer finds it automatically. Set this to an absolute path if
# you installed `openvisio` globally instead.
OPENVISIO_CLI=

# Node heap (MB) for the indexing child process. Bump for very large repos.
OPENVISIO_NODE_MEM_MB=2048

# Comma-separated tree-sitter grammars to skip while indexing (e.g. swift). Swift
# is already skipped by default on Node builds where its grammar can crash V8.
OPENVISIO_DISABLE_GRAMMARS=
